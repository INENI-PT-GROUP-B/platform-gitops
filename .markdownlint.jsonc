{
  // Enable all rules by default, then relax a few that do not fit our docs.
  "default": true,
  // Line length: prose and tables wrap freely in our Markdown.
  "MD013": false,
  // Allow inline HTML (badges, details blocks).
  "MD033": false,
  // Allow documents that do not start with a top-level heading.
  "MD041": false
}
